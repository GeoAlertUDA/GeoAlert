{
  "expo": {
    "name": "GeoAlert",
    "slug": "geoalert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "geoalert",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geoalertuda.geoalert",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GeoAlert usa tu ubicación para mostrarte en el mapa y calcular distancias.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GeoAlert necesita acceder a tu ubicación en segundo plano para evaluar alarmas activas.",
        "NSLocationAlwaysUsageDescription": "GeoAlert necesita acceder a tu ubicación en segundo plano para evaluar alarmas activas."
      },
      "config": {
        "googleMapsApiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_KEY_IOS}"
      }
    },
    "android": {
      "package": "com.geoalertuda.geoalert",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_KEY_ANDROID}"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationWhenInUsePermission": "GeoAlert usa tu ubicación para mostrarte en el mapa y calcular distancias.",
          "locationAlwaysAndWhenInUsePermission": "GeoAlert necesita acceder a tu ubicación en segundo plano para evaluar alarmas activas."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
